{
  "name": "cdp-custodial-access",
  "version": "0.1.0",
  "description": "CDP-based browser automation SDK with stealth and MCP server",
  "license": "MIT",
  "author": "Mohit Goyal",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohit-goyal/cdp-custodial-access"
  },
  "keywords": [
    "cdp",
    "chrome-devtools-protocol",
    "browser-automation",
    "puppeteer",
    "stealth",
    "web-scraping",
    "mcp",
    "model-context-protocol"
  ],
  "type": "module",
  "main": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "bin": {
    "cdp-custodial-access": "./dist/mcp/index.js",
    "cdp": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:stealth": "vitest run tests/stealth",
    "test:watch": "vitest",
    "mcp": "node dist/mcp/index.js",
    "lint": "eslint src/"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
